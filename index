<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Your Personal Success Code | Numerology Reading</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:wght@300;400;600&family=Josefin+Sans:wght@300;400&display=swap" rel="stylesheet">
<style>
:root {
  --deep: #1a0a2e;
  --purple: #350c48;
  --mid: #5c1a7a;
  --gold: #c9a84c;
  --gold-light: #e8d08a;
  --cream: #f5edd9;
  --lavender: #caafe0;
  --text: #f0e8d8;
}
* { margin:0; padding:0; box-sizing:border-box; }
body {
  font-family:'Cormorant Garamond',serif;
  background:var(--deep);
  color:var(--text);
  min-height:100vh;
  overflow-x:hidden;
}
body::before {
  content:'';
  position:fixed; top:0; left:0; right:0; bottom:0;
  background-image:
    radial-gradient(1px 1px at 20% 30%,rgba(201,168,76,.6) 0%,transparent 100%),
    radial-gradient(1px 1px at 80% 10%,rgba(255,255,255,.4) 0%,transparent 100%),
    radial-gradient(1.5px 1.5px at 60% 70%,rgba(201,168,76,.4) 0%,transparent 100%),
    radial-gradient(1px 1px at 40% 80%,rgba(255,255,255,.3) 0%,transparent 100%),
    radial-gradient(1px 1px at 10% 60%,rgba(202,175,224,.5) 0%,transparent 100%),
    radial-gradient(1px 1px at 90% 50%,rgba(255,255,255,.3) 0%,transparent 100%),
    radial-gradient(1.5px 1.5px at 30% 20%,rgba(202,175,224,.4) 0%,transparent 100%),
    radial-gradient(1px 1px at 70% 40%,rgba(201,168,76,.3) 0%,transparent 100%),
    radial-gradient(1px 1px at 50% 15%,rgba(255,255,255,.5) 0%,transparent 100%),
    radial-gradient(1px 1px at 85% 85%,rgba(202,175,224,.4) 0%,transparent 100%),
    radial-gradient(1px 1px at 15% 90%,rgba(255,255,255,.3) 0%,transparent 100%),
    radial-gradient(1.5px 1.5px at 55% 55%,rgba(201,168,76,.5) 0%,transparent 100%);
  pointer-events:none; z-index:0;
}
body::after {
  content:'';
  position:fixed; top:0; left:0; right:0; bottom:0;
  background:
    radial-gradient(ellipse 60% 40% at 20% 20%,rgba(53,12,72,.7) 0%,transparent 70%),
    radial-gradient(ellipse 50% 50% at 80% 80%,rgba(92,26,122,.4) 0%,transparent 70%),
    radial-gradient(ellipse 40% 60% at 60% 10%,rgba(201,168,76,.08) 0%,transparent 70%);
  pointer-events:none; z-index:0;
}
.wrap {
  position:relative; z-index:1;
  max-width:700px; margin:0 auto;
  padding:0 20px 80px;
}

/* HERO */
.hero { text-align:center; padding:60px 20px 40px; }
.badge {
  display:inline-block;
  font-family:'Josefin Sans',sans-serif;
  font-size:11px; letter-spacing:4px; text-transform:uppercase;
  color:var(--gold); border:1px solid rgba(201,168,76,.4);
  padding:8px 20px; border-radius:30px; margin-bottom:28px;
  animation:fadeUp .8s ease both;
}
.hero h1 {
  font-family:'Playfair Display',serif;
  font-size:clamp(28px,6vw,50px); line-height:1.2;
  color:var(--cream); margin-bottom:20px;
  animation:fadeUp .9s .2s ease both;
}
.hero h1 span { color:var(--gold); font-style:italic; }
.hero p {
  font-size:clamp(16px,2.5vw,19px); font-weight:300;
  color:rgba(240,232,216,.8); line-height:1.75;
  max-width:540px; margin:0 auto 32px;
  animation:fadeUp 1s .4s ease both;
}
.divider {
  display:flex; align-items:center; gap:14px;
  margin:20px auto; max-width:280px;
}
.divider::before,.divider::after {
  content:''; flex:1; height:1px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
}

/* CALCULATOR */
.calc-card {
  background:rgba(53,12,72,.6);
  border:1px solid rgba(201,168,76,.25);
  border-radius:22px; padding:42px 38px;
  text-align:center; backdrop-filter:blur(10px);
  animation:fadeUp 1s .5s ease both;
  box-shadow:0 20px 60px rgba(0,0,0,.4),inset 0 1px 0 rgba(201,168,76,.15);
  transition:opacity .4s;
}
.calc-card h2 {
  font-family:'Playfair Display',serif;
  font-size:25px; color:var(--cream); margin-bottom:10px;
}
.calc-card > p { font-size:17px; color:rgba(240,232,216,.7); margin-bottom:34px; }
.date-row { display:flex; gap:14px; justify-content:center; flex-wrap:wrap; margin-bottom:28px; }
.df { display:flex; flex-direction:column; align-items:center; gap:7px; }
.df label {
  font-family:'Josefin Sans',sans-serif;
  font-size:10px; letter-spacing:3px; text-transform:uppercase; color:var(--gold);
}
.df select {
  background:rgba(26,10,46,.8);
  border:1px solid rgba(201,168,76,.35); border-radius:12px;
  color:var(--cream); font-family:'Cormorant Garamond',serif;
  font-size:19px; text-align:center; padding:13px 8px; width:88px;
  outline:none; transition:border-color .3s,box-shadow .3s;
  appearance:none; -webkit-appearance:none; cursor:pointer;
}
.df select:focus { border-color:var(--gold); box-shadow:0 0 0 3px rgba(201,168,76,.15); }
.df select option { background:#1a0a2e; color:var(--cream); }
.df.yr select { width:108px; }
.err { color:#e07070; font-size:15px; margin-top:-8px; margin-bottom:8px; display:none; }
.gold-btn {
  display:inline-flex; align-items:center; gap:9px;
  background:linear-gradient(135deg,var(--gold) 0%,#a07828 100%);
  color:#1a0a2e; font-family:'Josefin Sans',sans-serif;
  font-size:13px; font-weight:400; letter-spacing:3px; text-transform:uppercase;
  border:none; border-radius:50px; padding:17px 42px;
  cursor:pointer; transition:all .3s;
  box-shadow:0 8px 30px rgba(201,168,76,.3); margin-top:4px;
}
.gold-btn:hover { transform:translateY(-2px); box-shadow:0 14px 40px rgba(201,168,76,.45); }

/* LOADING */
.loader { display:none; text-align:center; padding:50px; }
.spinner {
  width:50px; height:50px;
  border:2px solid rgba(201,168,76,.2); border-top-color:var(--gold);
  border-radius:50%; animation:spin .8s linear infinite;
  margin:0 auto 16px;
}
.loader-txt { font-family:'Josefin Sans',sans-serif; font-size:11px; letter-spacing:3px; color:var(--gold); }

/* CONTENT BLOCKS — hidden by default */
.block {
  display:none; margin-top:50px;
  animation:fadeUp .7s ease forwards;
}

/* Intro block */
.intro-card {
  background:rgba(53,12,72,.6);
  border:1px solid rgba(201,168,76,.2);
  border-radius:20px; padding:36px 34px;
  text-align:center; backdrop-filter:blur(10px);
}
.intro-card h3 {
  font-family:'Playfair Display',serif;
  font-size:clamp(20px,4vw,28px); color:var(--cream); margin-bottom:20px;
}
.intro-card p {
  font-size:18px; line-height:1.9;
  color:rgba(240,232,216,.88); white-space:pre-wrap; text-align:left;
}

/* Key section */
.key-lbl {
  display:inline-block; margin-bottom:16px;
  font-family:'Josefin Sans',sans-serif;
  font-size:10px; letter-spacing:4px; text-transform:uppercase;
  color:var(--gold); background:rgba(201,168,76,.1);
  border:1px solid rgba(201,168,76,.25); padding:5px 15px; border-radius:20px;
}
.key-intro-box {
  background:rgba(53,12,72,.55);
  border:1px solid rgba(202,175,224,.15);
  border-radius:17px; padding:26px 28px; margin-bottom:22px;
}
.key-intro-box h4 {
  font-family:'Playfair Display',serif;
  font-size:21px; color:var(--cream); margin-bottom:12px; line-height:1.35;
}
.key-intro-box p { font-size:17px; line-height:1.85; color:rgba(240,232,216,.85); }
.num-circle {
  width:70px; height:70px; border-radius:50%;
  background:linear-gradient(135deg,var(--mid) 0%,var(--purple) 100%);
  border:2px solid var(--gold);
  font-family:'Playfair Display',serif; font-size:29px;
  color:var(--gold-light); display:flex; align-items:center; justify-content:center;
  margin:0 auto 20px;
  box-shadow:0 4px 24px rgba(201,168,76,.35);
}
.key-img {
  width:100%; max-width:440px; border-radius:15px;
  margin:0 auto 22px; display:block;
  box-shadow:0 10px 40px rgba(0,0,0,.5);
}
.key-desc {
  background:rgba(53,12,72,.5);
  border:1px solid rgba(202,175,224,.2);
  border-radius:17px; padding:26px 28px;
  font-size:18px; line-height:1.9;
  color:rgba(240,232,216,.92); white-space:pre-wrap; text-align:left;
}

/* Progress tracker */
.tracker {
  display:flex; align-items:center; justify-content:center;
  gap:8px; flex-wrap:wrap; margin:28px 0 22px;
}
.tc {
  width:44px; height:44px; border-radius:50%;
  font-family:'Playfair Display',serif; font-size:17px;
  display:flex; align-items:center; justify-content:center;
  transition:all .5s ease;
}
.tc.on {
  background:linear-gradient(135deg,var(--mid),var(--purple));
  border:2px solid var(--gold); color:var(--gold-light);
  box-shadow:0 0 14px rgba(201,168,76,.4);
}
.tc.off {
  border:2px solid rgba(201,168,76,.25);
  color:rgba(201,168,76,.35);
}
.tc.off::after { content:'?'; }
.tsep { font-size:16px; color:rgba(201,168,76,.3); }

/* Reveal button */
.rev-btn {
  display:block; width:100%; max-width:420px; margin:26px auto 0;
  background:linear-gradient(135deg,var(--purple) 0%,var(--mid) 100%);
  color:var(--cream); font-family:'Josefin Sans',sans-serif;
  font-size:12px; letter-spacing:3px; text-transform:uppercase;
  border:1px solid rgba(201,168,76,.4); border-radius:50px;
  padding:17px 28px; cursor:pointer; transition:all .3s;
  box-shadow:0 8px 28px rgba(0,0,0,.3); text-align:center;
}
.rev-btn:hover { transform:translateY(-2px); border-color:var(--gold); box-shadow:0 14px 36px rgba(201,168,76,.25); }

/* Email gate */
.gate-card {
  text-align:center; padding:48px 38px;
  background:linear-gradient(135deg,rgba(53,12,72,.9) 0%,rgba(26,10,46,.9) 100%);
  border:1px solid rgba(201,168,76,.35); border-radius:22px;
  backdrop-filter:blur(10px);
  box-shadow:0 20px 60px rgba(0,0,0,.5);
}
.gate-card .icon { font-size:38px; margin-bottom:18px; }
.gate-card h3 {
  font-family:'Playfair Display',serif;
  font-size:clamp(20px,4vw,27px); color:var(--cream); margin-bottom:12px;
}
.gate-card > p { font-size:17px; color:rgba(240,232,216,.75); margin-bottom:28px; line-height:1.7; }
.gate-form { display:flex; flex-direction:column; gap:13px; max-width:390px; margin:0 auto; }
.gate-form input {
  background:rgba(26,10,46,.8);
  border:1px solid rgba(201,168,76,.35); border-radius:12px;
  padding:15px 18px; color:var(--cream);
  font-family:'Cormorant Garamond',serif; font-size:18px;
  outline:none; transition:border-color .3s; text-align:center;
}
.gate-form input::placeholder { color:rgba(240,232,216,.4); }
.gate-form input:focus { border-color:var(--gold); box-shadow:0 0 0 3px rgba(201,168,76,.15); }

/* Code reveal */
.code-card {
  text-align:center; padding:48px 28px;
  background:linear-gradient(135deg,rgba(53,12,72,.8) 0%,rgba(92,26,122,.3) 100%);
  border:1px solid rgba(201,168,76,.3); border-radius:22px;
}
.code-card h3 { font-family:'Playfair Display',serif; font-size:27px; color:var(--cream); margin-bottom:10px; }
.code-card > p { font-size:16px; color:rgba(240,232,216,.7); margin-bottom:28px; }
.code-nums { display:flex; justify-content:center; gap:14px; flex-wrap:wrap; margin-bottom:18px; }
.cn {
  width:56px; height:56px; border-radius:50%;
  background:linear-gradient(135deg,var(--mid),var(--purple));
  border:2px solid var(--gold);
  font-family:'Playfair Display',serif; font-size:23px; color:var(--gold-light);
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 4px 20px rgba(201,168,76,.3);
  animation:glow 3s ease infinite;
}
.cn:nth-child(2){animation-delay:.4s}
.cn:nth-child(3){animation-delay:.8s}
.cn:nth-child(4){animation-delay:1.2s}
.cn:nth-child(5){animation-delay:1.6s}

/* CTA */
.cta-btn {
  display:block; width:100%; max-width:440px; margin:38px auto 0;
  text-align:center;
  background:linear-gradient(135deg,var(--gold) 0%,#c4932a 50%,var(--gold) 100%);
  background-size:200% 100%;
  color:#1a0a2e; font-family:'Josefin Sans',sans-serif;
  font-size:14px; letter-spacing:3px; text-transform:uppercase;
  text-decoration:none; border:none; border-radius:50px;
  padding:21px 38px; cursor:pointer; transition:all .4s;
  box-shadow:0 10px 40px rgba(201,168,76,.4);
  animation:shimmer 3s ease infinite;
}
.cta-btn:hover { transform:translateY(-3px); box-shadow:0 20px 60px rgba(201,168,76,.6); }
.cta-note { text-align:center; font-size:15px; color:rgba(240,232,216,.5); margin-top:14px; font-style:italic; }

/* ANIMATIONS */
@keyframes fadeUp   { from{opacity:0;transform:translateY(22px)} to{opacity:1;transform:translateY(0)} }
@keyframes spin     { to{transform:rotate(360deg)} }
@keyframes glow     { 0%,100%{box-shadow:0 4px 20px rgba(201,168,76,.3)} 50%{box-shadow:0 4px 30px rgba(201,168,76,.6)} }
@keyframes shimmer  { 0%,100%{background-position:0% 50%} 50%{background-position:100% 50%} }

/* MOBILE */
@media(max-width:520px){
  .calc-card{padding:28px 16px}
  .df select{width:74px;font-size:17px}
  .df.yr select{width:98px}
  .key-desc,.key-intro-box{padding:20px 16px;font-size:16px}
  .gate-card{padding:34px 18px}
  .intro-card{padding:26px 18px}
  .intro-card p{font-size:16px}
}
</style>
</head>
