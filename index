// ── EMAIL GATE ────────────────────────────────────────────────
function showGate(){ show('b-gate'); }

function submitEmail(){
  const name=document.getElementById('g-name').value.trim();
  const email=document.getElementById('g-email').value.trim();
  const e=document.getElementById('email-err');
  if(!name||!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){e.style.display='block';return;} e.style.display='none';
  try{
    firebase.firestore().collection('email').add({
      name,email,day:N.day,month:N.month,year:N.year,
      dateOfBirth: N.day + '/' + N.month + '/' + N.year,
      personalityNumber:N.pNum,ancestryNumber:N.mNum,
      moneyNumber:N.yNum,destinyNumber:N.dNum,healthNumber:N.hNum,
      timestamp:new Date().toISOString()
    }).catch(e=>console.log('Firebase:',e));
  }catch(e){console.log('Firebase not available');}
  document.getElementById('b-gate').style.display='none';
  showKey3();
}

