// ── HELPERS ───────────────────────────────────────────────────
function reduce(n){ while(n>9) n=String(n).split('').reduce((s,d)=>s+parseInt(d),0); return n; }

function show(id){
  const el=document.getElementById(id);
  el.style.display='block';
  requestAnimationFrame(()=>{ el.style.opacity='1'; });
  setTimeout(()=>el.scrollIntoView({behavior:'smooth',block:'start'}),120);
}

function tracker(id, unlocked){
  const el=document.getElementById(id);
  el.innerHTML='';
  for(let i=0;i<5;i++){
    const c=document.createElement('div');
    if(i<unlocked.length){
      c.className='tc on'; c.textContent=unlocked[i];
    } else {
      c.className='tc off';
    }
    el.appendChild(c);
    if(i<4){ const s=document.createElement('div'); s.className='tsep'; s.textContent='—'; el.appendChild(s); }
  }
}

